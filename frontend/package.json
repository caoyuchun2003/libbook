  "scripts": {
    "dev": "vite --host",
    "build": "vite build",
    "preview": "vite preview --host",
    "setup-docs": "bash setup-docs.sh || node -e \"const fs=require('fs'),path=require('path');const target=path.join(__dirname,'public/docs');if(!fs.existsSync(target)){fs.symlinkSync(path.join(__dirname,'../../docs'),target,'dir');console.log('✅ 文档符号链接创建成功');}else{console.log('✅ 文档符号链接已存在');}\""
  },
