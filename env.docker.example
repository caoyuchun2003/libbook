# Docker 环境变量配置示例
# 复制此文件内容到 .env 文件，或使用 docker-compose 的 env_file 选项

# 应用配置
APP_NAME=宇春书城
APP_ENV=production
APP_KEY=base64:YOUR_APP_KEY_HERE
APP_DEBUG=false
APP_URL=http://localhost

# 数据库配置
DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=libbook
DB_USERNAME=libbook_user
DB_PASSWORD=libbook_password
DB_ROOT_PASSWORD=root_password

# 缓存配置
CACHE_DRIVER=file
SESSION_DRIVER=file
QUEUE_CONNECTION=sync

# 端口配置
FRONTEND_PORT=80
BACKEND_PORT=8000
DB_PORT=3306

# 邮件配置（可选）
MAIL_MAILER=smtp
MAIL_HOST=mailhog
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="noreply@example.com"
MAIL_FROM_NAME="${APP_NAME}"
